{
  "db_name": "PostgreSQL",
  "query": "SELECT o.id,o.name,o.created_at FROM organizations o \n        INNER JOIN membership m \n        ON m.org_id = o.id \n        WHERE m.user_id = $1 \n        AND o.is_deleted = false \n        AND ($2::timestamptz IS NULL OR o.created_at > $2) \n        ORDER BY o.created_at DESC\n        LIMIT $3",
